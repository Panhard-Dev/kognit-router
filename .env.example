# ===========================================
# Kognit Router — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# All variables are optional — defaults work for local dev.

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Data ---
KOGNIT_DATA_FILE=./server/data.json

# --- API Key Auth ---
# Enable API key requirement on /v1 and /api routes
KOGNIT_REQUIRE_API_KEY=false

# Admin token for write operations on /api (POST/PUT/PATCH/DELETE)
# Leave empty to disable admin auth (open access — local dev only)
KOGNIT_ADMIN_TOKEN=

# --- CORS ---
# Origin allowed for CORS (defaults to PUBLIC_ORIGIN or localhost)
KOGNIT_CORS_ORIGIN=

# --- Origins ---
KOGNIT_LOCAL_ORIGIN=
KOGNIT_LOCAL_API_ORIGIN=
KOGNIT_PUBLIC_ORIGIN=

# --- Rate Limiting ---
KOGNIT_RATE_LIMIT_MAX=120

# --- Request Size Limit ---
KOGNIT_REQUEST_BODY_LIMIT=50mb

# --- Trust Proxy ---
# Set to 1 when behind a reverse proxy (Docker, Render, etc.)
KOGNIT_TRUST_PROXY=0

# --- OAuth: Gemini CLI ---
GEMINI_CLI_CLIENT_SECRET=

# --- OAuth: Antigravity ---
ANTIGRAVITY_CLIENT_ID=
ANTIGRAVITY_CLIENT_SECRET=

# --- ZCode / Z.ai ---
KOGNIT_ZCODE_TOKEN=
KOGNIT_ZCODE_ACCOUNTS_JSON=

# --- Cloudflare Tunnel ---
# Path to cloudflared binary (auto-detected if not set)
KOGNIT_CLOUDFLARED_PATH=

# --- GLM Proxy (ZCode) ---
ZCODE_PROXY_HOST=127.0.0.1
ZCODE_PROXY_PORT=3075
ZCODE_PROXY_DATA_DIR=
ZCODE_CONFIG_FILE=
ZCODE_PROXY_VERBOSE=0
ZCODE_FORCE_UTF8=0

# --- Captcha Bridge ---
ZCODE_CAPTCHA_BRIDGE=true
ZCODE_CAPTCHA_HEADLESS=true
ZCODE_CAPTCHA_CLIENT_PREFERENCE=standalone-browser
ZCODE_CAPTCHA_HEADLESS_EXECUTABLE=
ZCODE_CAPTCHA_HEADLESS_PROFILE_DIR=
ZCODE_CAPTCHA_HEADLESS_RESTART_DELAY_MS=30000
ZCODE_ACCOUNT_CREATOR_ENABLED=false
